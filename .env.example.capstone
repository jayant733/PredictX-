# ============================================================
# Autonomous Traders — environment variables
# Copy to ".env" and fill in. Never commit the real .env.
# ============================================================

# --- LLM (pick ONE; both have free tiers) ---
# GLM-5.2 via Cloudflare AI Gateway (preferred — free, fast)
GLM_API_KEY=
# Gemini as a fallback (free tier)
GEMINI_API_KEY=
# Cloudflare Workers AI credentials for bot-specific models
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# --- Web search for the Researcher agent ---
# https://brave.com/search/api/  (free tier = 2000 queries/month)
BRAVE_API_KEY=

# --- Market data ---
# Polygon.io free tier = 5 API calls/min, end-of-day data (no realtime).
# Leave blank to use the local free market_server (synthetic + yfinance).
POLYGON_API_KEY=

# --- Push notifications (trader alerts) ---
# https://pushover.net/  (free tier = 10,000 msgs/month)
PUSHOVER_USER=
PUSHOVER_TOKEN=

# --- Agent memory (mcp-memory-libsql) ---
# Each agent gets its own DB file under data/memory/.
# The trader name is appended automatically (e.g. file:./data/memory/trader-warren.db).
LIBSQL_BASE_URL=file:./data/memory

# --- Runtime ---
NODE_ENV=development
